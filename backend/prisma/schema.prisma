generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Standing {
  id           Int      @id @default(autoincrement())
  tableType    String   @default("apertura")
  team         String
  group        String
  played       Int      @default(0)
  won          Int      @default(0)
  drawn        Int      @default(0)
  lost         Int      @default(0)
  goalsFor     Int      @default(0)
  goalsAgainst Int      @default(0)
  points       Int      @default(0)
  form         String   @default("")
  logo         String   @default("")
  createdAt    DateTime @default(now())
}

model Match {
  id           Int      @id @default(autoincrement())
  flashscoreId String   @unique
  homeTeam     String
  awayTeam     String
  homeScore    Int?
  awayScore    Int?
  status       String
  minute       String?
  matchDate    DateTime
  competition  String
  updatedAt    DateTime @updatedAt
}
